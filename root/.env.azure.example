# Azure General
USE_AZURE=true

# Azure Storage Queue
AZURE_STORAGE_ACCOUNT_NAME=your-storage-account-name
AZURE_QUEUE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=your-storage-account-name;AccountKey=your-storage-account-key;EndpointSuffix=core.windows.net
AZURE_QUEUE_NAME=submissions

# Cosmos DB Configuration
COSMOS_ACCOUNT_NAME=your-cosmos-account-name
COSMOS_KEY=your-cosmos-key
COSMOS_ENDPOINT=https://your-cosmos-account-name.documents.azure.com:443/
COSMOS_DATABASE_NAME=sentio-db
COSMOS_CONTAINER_NAME=metadata

# Application Insights
APPLICATIONINSIGHTS_CONNECTION_STRING=InstrumentationKey=your-instrumentation-key;IngestionEndpoint=https://your-ingestion-endpoint/

# Qdrant Vector DB
QDRANT_URL=your-qdrant-url
QDRANT_API_KEY=your-qdrant-api-key
COLLECTION_NAME=Sentio_docs_v3

# Jina AI API (for embedding generation)
JINA_API_KEY=your-jina-api-key

# App Configuration
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

# LLM Configuration
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama2
ENABLE_WEB_SEARCH=1

# OpenRouter configuration
OPENROUTER_API_KEY=your-openrouter-api-key
OPENROUTER_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=deepseek/deepseek-r1-0528-qwen3-8b:free

# Brave Search API
BRAVE_API_KEY=your-brave-api-key